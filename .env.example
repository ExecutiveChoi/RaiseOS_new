# =============================================================
# SYNDICHECK ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# For production, add these in the Vercel dashboard under:
#   Project Settings → Environment Variables
# =============================================================

# --- SUPABASE ---
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase DB direct connection (for Drizzle ORM migrations)
# Get from: Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- STRIPE ---
# Get these from: https://dashboard.stripe.com → Developers → API keys
# Use test keys (sk_test_...) during development, live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_your-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Get from: Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.vercel.app/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Get these after creating products in Stripe Dashboard:
# Product: "SyndiCheck Pro" → Price: $29/month → copy Price ID
STRIPE_PRICE_PRO_MONTHLY=price_your-pro-price-id
# Product: "SyndiCheck Verified" → Price: $99/month → copy Price ID
STRIPE_PRICE_VERIFIED_MONTHLY=price_your-verified-price-id
# Product: "SyndiCheck Premium" → Price: $299/month → copy Price ID
STRIPE_PRICE_PREMIUM_MONTHLY=price_your-premium-price-id

# --- AI (choose one or both) ---
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (optional, used for complex document analysis):
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- EMAIL (RESEND) ---
# Get from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_your-resend-key

# --- CACHE (UPSTASH REDIS) ---
# Create free database at: https://console.upstash.com
# Get REST URL and Token from the database details page
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- EXTERNAL DATA APIS ---
# RentCast (property verification): https://app.rentcast.io/api
# Free tier: 50 calls/month
RENTCAST_API_KEY=your-rentcast-key

# SEC API (optional paid tier for enhanced Form D search):
# https://sec-api.io — $55/month startup tier
# Leave blank to use the free SEC EDGAR API instead
SEC_API_KEY=

# --- CRON SECURITY ---
# Generate a random secret to protect cron endpoints from unauthorized calls
# Run: openssl rand -base64 32
CRON_SECRET=your-random-cron-secret-here

# --- APP ---
# Your production domain (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
